# Server (Render PORT otomatik atanır; yerelde 3001 veya istediğiniz port)
PORT=3001
# Dinleme adresi — Render/Docker için varsayılan 0.0.0.0 (server.js)
# HOST=127.0.0.1
NODE_ENV=development

# Database — PostgreSQL
# Seçenek A (Render önerilen): PostgreSQL eklentisinden gelen tek satır bağlantı
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Render managed DB için TLS:
# DB_SSL=true
#
# Seçenek B (ayrı değişkenler — yerel Docker / manuel kurulum)
# Köke `npm run dev:db` ile PostgreSQL açıyorsanız şifre docker-compose ile aynı olmalı:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=healthai_db
DB_USER=healthai_user
DB_PASS=healthai_pass

# JWT
JWT_ACCESS_SECRET=change_this_to_a_long_random_string
JWT_REFRESH_SECRET=change_this_to_another_long_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=HEALTH AI <no-reply@healthai.edu>

FRONTEND_URL=http://localhost:5173
# Üretimde tarayıcının geldiği tam köken (Railway: https://your-app.up.railway.app). İsterseniz ek:
# CORS_ORIGINS=https://başka-on-yüz.railway.app,https://preview.vercel.app
API_PUBLIC_URL=http://localhost:3001

# Security
BCRYPT_SALT_ROUNDS=12
DB_AUTO_SYNC=true
